# =============================================================
#  Vibe MyBooks — environment configuration
# =============================================================
# Copy this file to `.env` and fill in the REQUIRED section below.
# On a fresh install, scripts/install.sh does this for you (generates
# strong random values). Only hand-edit if you're bootstrapping without
# that script.
#
# After first boot do NOT rotate the crypto keys. Each one wraps data
# at rest; changing them after data exists makes that data unreadable.

# --- REQUIRED ------------------------------------------------------
# Generate each of the three 64-hex-char values with:
#     openssl rand -hex 32
# Generate the DB password with:
#     openssl rand -base64 32 | tr -d '/+='
#
# Compose refuses to start with any of these unset (see docker-compose.yml).

POSTGRES_PASSWORD=
JWT_SECRET=
ENCRYPTION_KEY=
PLAID_ENCRYPTION_KEY=

# --- Database (Compose composes DATABASE_URL from these three) -----
POSTGRES_USER=kisbooks
POSTGRES_DB=kisbooks
# Only set DATABASE_URL directly if running the API outside Compose
# against an existing Postgres. Otherwise leave it commented.
# DATABASE_URL=postgresql://kisbooks:CHANGE_ME@db:5432/kisbooks

# --- Redis ----------------------------------------------------------
REDIS_URL=redis://redis:6379

# --- Auth expirations ----------------------------------------------
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Server ---------------------------------------------------------
PORT=3001
# Default production — the quick-start path gets a hardened box. The dev
# compose overlay (docker-compose.dev.yml) flips this to development;
# devs running npm outside Docker should export NODE_ENV=development in
# their shell.
NODE_ENV=production
CORS_ORIGIN=http://localhost:5173

# --- Email (optional — fill in to enable outbound mail) ------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# --- File storage ---------------------------------------------------
UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE_MB=10

# --- Plaid (optional — leave blank to disable bank connections) ----
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# NB: PLAID_ENCRYPTION_KEY lives in the REQUIRED section above. It
# wraps every encrypted-at-rest column (Plaid + Stripe + OAuth + TFA),
# not only Plaid tokens, so it is required whether or not Plaid is on.

# --- LLM (optional — enables receipt OCR + AI categorization) ------
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514

# --- Cloud storage OAuth (optional) --------------------------------
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
STORAGE_ENCRYPTION_KEY=
STORAGE_CACHE_DIR=/data/cache
STORAGE_CACHE_MAX_SIZE_GB=5

# --- Backup (optional — encryption key only needed for encrypted backups) ---
BACKUP_DIR=/data/backups
BACKUP_ENCRYPTION_KEY=

# --- Tailscale remote access (optional — pair via in-app wizard if blank) ---
# Generate a reusable auth key at https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=
TS_HOSTNAME=mybooks
TS_EXTRA_ARGS=--ssh=false
TAILSCALE_SOCKET_PATH=/var/run/tailscale/tailscaled.sock
