# Database
# In Docker Compose these three values compose DATABASE_URL for you. Change
# POSTGRES_PASSWORD to something real — the compose file refuses to start if
# it's left blank.
POSTGRES_USER=kisbooks
POSTGRES_PASSWORD=
POSTGRES_DB=kisbooks
# If you run the API outside Compose (e.g. against an existing Postgres),
# set DATABASE_URL directly and ignore the three vars above.
DATABASE_URL=postgresql://kisbooks:CHANGE_ME@db:5432/kisbooks

# Redis
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Installation encryption key — 64-char hex (32 bytes). Used to encrypt the
# installation sentinel file at /data/.sentinel. The setup wizard generates
# this automatically and writes it to /data/config/.env. Do NOT regenerate
# after setup — a new key cannot decrypt the existing sentinel, and the app
# will refuse to start.
ENCRYPTION_KEY=

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# File storage
UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE_MB=10

# Plaid (optional — leave blank to disable bank connections)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_ENCRYPTION_KEY=  # 64-char hex (32 bytes) — used to encrypt Plaid access tokens at rest

# LLM (for receipt OCR and AI categorization)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514

# Cloud Storage OAuth (system-level — set to enable cloud storage options for tenants)
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
STORAGE_ENCRYPTION_KEY=  # defaults to JWT_SECRET if not set
STORAGE_CACHE_DIR=/data/cache
STORAGE_CACHE_MAX_SIZE_GB=5

# Backup
BACKUP_DIR=/data/backups
BACKUP_ENCRYPTION_KEY=

# Tailscale remote access (optional — leave TS_AUTHKEY blank to pair via the in-app wizard)
# Generate a reusable auth key at https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=
TS_HOSTNAME=mybooks
TS_EXTRA_ARGS=--ssh=false
TAILSCALE_SOCKET_PATH=/var/run/tailscale/tailscaled.sock
