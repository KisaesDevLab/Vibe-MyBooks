# =============================================================
#  Vibe MyBooks — environment configuration
# =============================================================
# Copy this file to `.env` and fill in the REQUIRED section below.
# On a fresh install, scripts/install.sh does this for you (generates
# strong random values). Only hand-edit if you're bootstrapping without
# that script.
#
# After first boot do NOT rotate the crypto keys. Each one wraps data
# at rest; changing them after data exists makes that data unreadable.

# --- REQUIRED ------------------------------------------------------
# Generate each of the three 64-hex-char values with:
#     openssl rand -hex 32
# Generate the DB password with:
#     openssl rand -base64 32 | tr -d '/+='
#
# Compose refuses to start with any of these unset (see docker-compose.yml).

POSTGRES_PASSWORD=
JWT_SECRET=
ENCRYPTION_KEY=
PLAID_ENCRYPTION_KEY=

# --- Database (Compose composes DATABASE_URL from these three) -----
POSTGRES_USER=kisbooks
POSTGRES_DB=kisbooks
# Only set DATABASE_URL directly if running the API outside Compose
# against an existing Postgres. Otherwise leave it commented.
# DATABASE_URL=postgresql://kisbooks:CHANGE_ME@db:5432/kisbooks

# --- Redis ----------------------------------------------------------
REDIS_URL=redis://redis:6379
# Opt-in Redis-backed rate limiter store. When off (the default),
# limiters use an in-memory counter per container — fine for single-
# instance installs. Set to 1 for multi-instance / autoscaled deploys
# so login + global limiters share state and survive restart.
RATE_LIMIT_REDIS=0

# --- Trust proxy (security-sensitive) ------------------------------
# Controls whether Express reads the client IP/protocol/host from
# X-Forwarded-* headers. Every consumer of these (rate limiters,
# staff IP allowlist, Stripe IP allowlist, invoice-link builder)
# makes authorization or URL decisions based on them.
#
# Defaults to `loopback` when unset — safe for direct-exposure
# installs. Set to `true` behind a reverse proxy or the Cloudflare
# Tunnel sidecar that correctly strips X-Forwarded-* from client
# input; otherwise the spoofable headers let attackers bypass IP
# checks and forge link hostnames.
#
# Advanced: supply a comma-separated CIDR / keyword list (e.g.
# `10.0.0.0/8,loopback`) or a numeric hop count (e.g. `1` when
# there's exactly one proxy in front of the appliance).
TRUST_PROXY=

# --- Auth expirations ----------------------------------------------
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# Admin idle timeout. Super-admin routes (/admin/*) reject tokens
# older than this, so walking away from the appliance forces a
# re-login before the next admin-panel click. Staff (non-admin)
# session length is governed by JWT_ACCESS_EXPIRY + refresh token.
JWT_ADMIN_MAX_AGE=30m

# --- Server ---------------------------------------------------------
PORT=3001
# Default production — the quick-start path gets a hardened box. The dev
# compose overlay (docker-compose.dev.yml) flips this to development;
# devs running npm outside Docker should export NODE_ENV=development in
# their shell.
NODE_ENV=production
CORS_ORIGIN=http://localhost:5173

# --- Distribution-mode knobs (vibe-distribution-plan) ----------------
# Single-app mode (default): leave PUBLIC_URL pointing at the dev SPA;
# COOKIE_PATH=/, COOKIE_SECURE unset (auto-on in production NODE_ENV).
# Multi-app mode (Caddy ingress at https://<host>/mybooks/): set
#   PUBLIC_URL=https://vibe.local/mybooks
#   COOKIE_PATH=/mybooks         # cookie isolation from sibling apps
#   COOKIE_SECURE=1              # the front door is always HTTPS
#   WEBAUTHN_RP_ID=vibe.local    # passkey RP — must match the host
#                                # NOTE: all four Vibe products on the
#                                # same vibe.local share rpId, so a
#                                # passkey enrolled in one app is
#                                # selectable in the others. Acceptable
#                                # for a single-firm appliance with one
#                                # operator. Move the passkey-using app
#                                # to a subdomain if isolation matters.
PUBLIC_URL=http://localhost:5173
COOKIE_PATH=/
# COOKIE_SECURE=
# WEBAUTHN_RP_ID=

# --- GLM-OCR sidecar (optional, vibe-distribution-plan D7) ---------
# `docker compose --profile glm-ocr up -d` brings up a llama.cpp
# server on port 8090 (internal) running the GLM-OCR GGUF model.
# After starting, configure the API to use it via the admin UI:
#   AI Processing → GLM-OCR → mode: local, base URL: http://glm-ocr:8090
# The default image references the Vibe-GLM-OCR appliance; override
# via GLM_OCR_IMAGE if you maintain a custom build. Allow ~3 GB of
# RAM headroom for the model's resident set + KV cache.
# GLM_OCR_IMAGE=ghcr.io/kisaesdevlab/vibe-glm-ocr:latest
# GLM_OCR_MEM_LIMIT=4g

# --- Licensing (vibe-distribution-plan D6) --------------------------
# DISABLE_LICENSE_CHECK=1 short-circuits the boot-time license probe.
# CI runs with this on; production appliances ship with both
# LICENSE_PUBLIC_KEY (PEM) and LICENSE_TOKEN (RS256 JWT). The installer
# fetches LICENSE_PUBLIC_KEY from licensing.kisaes.com and writes the
# operator-supplied token here at install time.
DISABLE_LICENSE_CHECK=1
# LICENSE_PUBLIC_KEY=
# LICENSE_TOKEN=

# --- Email (optional — fill in to enable outbound mail) ------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# --- File storage ---------------------------------------------------
UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE_MB=10

# --- Password hashing -----------------------------------------------
# bcrypt cost factor. Default 12 (≈250ms per hash on modern hardware).
# CLAUDE.md fixes the floor at 12; lower values ship but are rejected
# by policy review. Raise only after measuring login-path latency on
# the deployment's actual hardware — every +1 doubles the CPU cost.
BCRYPT_ROUNDS=12

# --- Plaid (optional — leave blank to disable bank connections) ----
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# NB: PLAID_ENCRYPTION_KEY lives in the REQUIRED section above. It
# wraps every encrypted-at-rest column (Plaid + Stripe + OAuth + TFA),
# not only Plaid tokens, so it is required whether or not Plaid is on.

# --- LLM (optional — enables receipt OCR + AI categorization) ------
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514

# --- Cloud storage OAuth (optional) --------------------------------
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
STORAGE_ENCRYPTION_KEY=
STORAGE_CACHE_DIR=/data/cache
STORAGE_CACHE_MAX_SIZE_GB=5

# --- Backup (optional — encryption key only needed for encrypted backups) ---
BACKUP_DIR=/data/backups
BACKUP_ENCRYPTION_KEY=

# --- Tailscale remote access (optional — pair via in-app wizard if blank) ---
# Generate a reusable auth key at https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=
TS_HOSTNAME=mybooks
TS_EXTRA_ARGS=--ssh=false
TAILSCALE_SOCKET_PATH=/var/run/tailscale/tailscaled.sock

# --- Cloudflare Tunnel (optional — only used with `--profile tunnel`) ---
# Customer-owned Cloudflare model: the firm creates their own tunnel in
# their own CF Zero Trust dashboard, pastes the token here, and brings
# the tunnel sidecar up with:
#   docker compose --profile tunnel up -d
# Setup walkthrough in docs/firm-cloudflare-setup.md. Leave blank on
# LAN-only installs; the cloudflared sidecar stays disabled.
#
# Tunnel token — from Zero Trust → Networks → Tunnels → <your tunnel>
# → "Install connector" screen. Copy everything AFTER `--token`.
CLOUDFLARE_TUNNEL_TOKEN=
# Turnstile site + secret keys — from cloudflare.com dashboard →
# Turnstile → Add site. TURNSTILE_SITE_KEY is safe to expose to the
# browser; TURNSTILE_SECRET_KEY is server-only. Use the literal string
# `disabled` in dev to skip verification entirely (see Phase 4 of the
# build plan).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Hardening flags (all default OFF) -----------------------------
# Staff IP allowlist — when set to 1, /api/v1/* requests from
# non-allowlisted IPs get a 403 (super-admin break-glass exempts).
# Populate the list via Admin → Security → Staff IP Allowlist
# BEFORE flipping this to 1, otherwise operators will lock themselves
# out.
STAFF_IP_ALLOWLIST_ENFORCED=0

# Stripe webhook IP allowlist — when set to 1, only Cloudflare-tracked
# Stripe webhook IPs can POST to /stripe-webhook. Leave 0 on LAN-only
# installs or during Stripe sandbox testing.
STRIPE_WEBHOOK_IP_ALLOWLIST_ENFORCED=0

# HaveIBeenPwned breach check on register/password-change. Default ON
# (this flag is the kill-switch). Set to 1 ONLY for offline/air-gapped
# installs where the k-anonymity HTTPS call to api.pwnedpasswords.com
# cannot succeed.
HIBP_DISABLED=0
HIBP_TIMEOUT_MS=3000

# cloudflared sidecar metrics endpoint. Default matches the compose
# sidecar's `--metrics 0.0.0.0:2000`. Override only if running
# cloudflared on a different host/port.
CLOUDFLARED_METRICS_URL=http://cloudflared:2000

# Audit-log alert threshold (ms) for tunnel-down. Default 2 minutes.
CLOUDFLARED_ALERT_THRESHOLD_MS=120000

# Rate-limit Redis degraded-mode alert. Emits a super-admin audit
# entry when RATE_LIMIT_REDIS=1 but the Redis connection fails and the
# limiter falls back to per-container in-memory counters. 1 = alert
# (recommended), 0 = silent.
RATE_LIMIT_REDIS_ALERT=1

# Backup-verification scheduler cadence (ms). Default 30 days. The
# worker periodically decrypts + parses the latest backup to prove it
# can be restored; failures land in the audit log.
BACKUP_VERIFY_INTERVAL_MS=2592000000

# --- Logging -------------------------------------------------------
# pino log level: trace|debug|info|warn|error|fatal. Default info.
LOG_LEVEL=info

# --- Image tag (docker-compose.prod.yml) ---------------------------
# Pins the GHCR image version for the three published images
# (vibe-mybooks-api, vibe-mybooks-web, vibe-mybooks-worker — see
# vibe-distribution-plan §image publishing). Defaults to `latest`
# for fresh installs but STRONGLY RECOMMENDED to pin after first
# boot — a specific tag (e.g., 1.4) prevents silent upgrade
# regressions. Browse tags at:
#   https://github.com/orgs/KisaesDevLab/packages?repo_name=Vibe-MyBooks
VIBE_MYBOOKS_VERSION=latest

# --- Split-level tags rollout (feature flags, all default off) -----
# Per docs/plans/split-level-tags-build-plan.md §10, flip these in
# order after the schema + dual-write migration is live:
#   1. TAGS_SPLIT_LEVEL_V2 — data-model cutover (ledger writes and
#      reports read line-level tag_id as authoritative). Safe to flip
#      per-tenant once migrations 0059–0063 are applied.
#   2. VITE_ENTRY_FORMS_V2 — two-line split-row entry form UI (web
#      bundle only, build-time). Rebuild the web image after flipping.
#   3. TAG_BUDGETS_V1 — tag-scoped budgets + Budget vs. Actuals.
# Rollback: set back to false; header-level tag columns remain intact
# through Phase 10 cleanup.
TAGS_SPLIT_LEVEL_V2=false
TAG_BUDGETS_V1=false
VITE_ENTRY_FORMS_V2=false
