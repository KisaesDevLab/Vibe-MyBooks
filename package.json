{
  "name": "kis-books",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted bookkeeping application",
  "workspaces": [
    "packages/shared",
    "packages/api",
    "packages/web",
    "packages/worker"
  ],
  "scripts": {
    "dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "license:audit": "bash scripts/license-audit.sh",
    "license:audit:quiet": "bash scripts/license-audit.sh --quiet",
    "license:audit:json": "bash scripts/license-audit.sh --json --quiet",
    "license:headers": "bash scripts/check-license-headers.sh",
    "license:headers:fix": "bash scripts/add-license-header.sh",
    "license:sbom": "bash scripts/generate-sbom.sh",
    "migrations:check": "bash scripts/check-migration-policy.sh",
    "any:check": "bash scripts/check-any-baseline.sh",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx,js,jsx,mjs,cjs,sql,sh,py}": "bash scripts/check-license-headers.sh",
    "packages/api/src/db/migrations/*.sql": "bash scripts/check-migration-policy.sh",
    "**/package.json": "bash scripts/license-audit.sh --quiet"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "Kisaes LLC",
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    },
    "unzipper": "^0.12.3"
  }
}
