# Vibe MyBooks Configuration
# Copy this file to .env and customize as needed.
# The installer generates a .env automatically with secure random secrets.

# Database (internal Docker network — no changes needed)
DATABASE_URL=postgresql://kisbooks:kisbooks@db:5432/kisbooks
REDIS_URL=redis://redis:6379

# Security (auto-generated — change in production)
JWT_SECRET=change-me-to-a-long-random-string-at-least-20-chars

# Server
PORT=3001
VITE_PORT=5173
NODE_ENV=production
CORS_ORIGIN=http://localhost:5173

# Email (optional — configure for password resets and invoice sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# File Storage
UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE_MB=10
