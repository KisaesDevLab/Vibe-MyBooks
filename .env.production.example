# Vibe MyBooks — Production Environment Variables
# Copy this file to .env and fill in the values

# Database
DB_PASSWORD=change-me-use-generated-password
DATABASE_URL=postgresql://kisbooks:${DB_PASSWORD}@db:5432/kisbooks

# Redis
REDIS_URL=redis://redis:6379

# Auth — MUST change in production
JWT_SECRET=change-me-use-scripts-generate-secrets

# Server
PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://your-domain.com

# Email (SMTP) — optional, required for sending invoices
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@your-domain.com

# File storage
UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE_MB=10

# Backup
BACKUP_DIR=/data/backups
BACKUP_ENCRYPTION_KEY=change-me-use-scripts-generate-secrets
