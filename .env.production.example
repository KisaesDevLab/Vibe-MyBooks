# Vibe MyBooks — Production Environment Variables
#
# The one-line installer (scripts/install.sh) generates this file for you with
# random secrets — you normally do NOT edit it by hand. This template is only
# for manual/advanced setups. Generate the four secrets with:
#   npx tsx scripts/generate-secrets.ts
# and paste them below. Every value marked "REQUIRED" must be set, or
# `docker compose up` aborts before starting (the compose file guards them).

# Database — the production compose reads POSTGRES_* directly (not DB_PASSWORD).
POSTGRES_USER=kisbooks
POSTGRES_PASSWORD=change-me-REQUIRED-generate-secrets   # REQUIRED
POSTGRES_DB=kisbooks

# Redis
REDIS_URL=redis://redis:6379

# Auth / crypto — MUST be strong random values in production (REQUIRED).
# ENCRYPTION_KEY and PLAID_ENCRYPTION_KEY are 64-hex-char (32-byte) keys; losing
# them makes stored credentials unrecoverable. Back them up off the machine.
JWT_SECRET=change-me-REQUIRED-generate-secrets          # REQUIRED
ENCRYPTION_KEY=change-me-REQUIRED-64-hex-chars          # REQUIRED
PLAID_ENCRYPTION_KEY=change-me-REQUIRED-64-hex-chars    # REQUIRED

# Server / ports
NODE_ENV=production
PORT=3001          # API (serves /health and /api/* only)
VITE_PORT=5173     # web UI + first-run setup wizard — the port you open
# CORS origin = the URL your browser uses. Local install: http://localhost:5173
# Behind a domain/tunnel: your https URL, e.g. https://books.example.com
CORS_ORIGIN=http://localhost:5173

# Email (SMTP) — optional, required for sending invoices
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@your-domain.com

# File storage
UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE_MB=10

# Backup
BACKUP_DIR=/data/backups
BACKUP_ENCRYPTION_KEY=change-me-use-scripts-generate-secrets

# Split-level tags rollout (feature flags, all default off)
# Flip in order after migrations 0059–0063 are applied, per
# docs/plans/split-level-tags-build-plan.md §10:
#   1. TAGS_SPLIT_LEVEL_V2 — line-level tag_id becomes authoritative
#      for ledger writes and report reads.
#   2. VITE_ENTRY_FORMS_V2 — two-line split-row entry form UI (web
#      bundle only, build-time — rebuild the web image to apply).
#   3. TAG_BUDGETS_V1 — tag-scoped budgets + Budget vs. Actuals report.
# Each flag is independently revertable; leave off during the initial
# dark deploy and flip per-tenant once you have validated the schema.
TAGS_SPLIT_LEVEL_V2=false
TAG_BUDGETS_V1=false
VITE_ENTRY_FORMS_V2=false
